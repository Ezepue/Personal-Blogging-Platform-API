# Base URL of the FastAPI backend. Used server-side by the API proxy
# (/api/[...proxy]), auth routes, and every server component that fetches data.
# In production this must point at the deployed backend, NOT localhost —
# server components run on the host, so localhost:8000 is unreachable there.
API_URL=http://localhost:8000

# Public URL of this frontend. Drives metadataBase for Open Graph/Twitter
# tags, canonical URLs, and absolute links in feeds. Set to the deployed origin.
SITE_URL=http://localhost:3000

# WebSocket endpoint for live notifications (client-side). Defaults to the
# browser origin with a ws(s):// scheme when unset; override only if the
# backend socket lives on a different host.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/notifications
